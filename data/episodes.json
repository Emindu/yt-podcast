    "title": "\u0db6\u0dd2\u0d82\u0daf\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0da7\u0db1\u0dca \u0d9c\u0db1\u0dca\u0db1 \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0db4\u0dd2\u0dba\u0dc0\u0dbb 4\u0d9a\u0dd2\u0db1\u0dca  \u0db8\u0dd6\u0dbd\u0dca\u200d\u0dba \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0da7 \u0dbd\u0d9f\u0dcf \u0dc0\u0dd9\u0db1\u0dca\u0db1\u0dda \u0d9a\u0ddc\u0dc4\u0ddc\u0db8\u0daf?",
    "description": "\u0db8\u0dda \u0dc0\u0dd3\u0da9\u0dd2\u0dba\u0ddd \u0d91\u0d9a\u0dda \u0db8\u0db8 \u0d9a\u0dad\u0dcf \u0d9a\u0dbb\u0db1\u0dca\u0db1\u0dda \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0db8\u0dd6\u0dbd\u0dca\u200d\u0dba \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab\u0dba\u0dda \u0d89\u0dad\u0dcf\u0db8 \u0dc0\u0dd0\u0daf\u0d9c\u0dad\u0dca\u0db8 \u0d89\u0dbd\u0d9a\u0dca\u0d9a \u0dc4\u0dad\u0dbb \u0d9c\u0dd0\u0db1. \u0daf\u0dd4\u0db4\u0dca\u0db4\u0dad\u0dca \u0d9a\u0db8\u0dda \u0d89\u0db3\u0dbd\u0dcf \u0db8\u0dd4\u0dbd\u0dca\u200d\u0dba\u0db8\u0dba \u0dc3\u0dca\u0dc0\u0dcf\u0db0\u0dd3\u0db1 \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0db6\u0dc0\u0da7 \u0db4\u0dad\u0dca\u0dc0\u0dd3\u0db8 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dba\u0db1 \u0d9c\u0db8\u0db1\u0dda \u0daf\u0dd3 \u0db8\u0dda \u0d89\u0dbd\u0d9a\u0dca\u0d9a \u0db4\u0dc3\u0dd4\u0d9a\u0dbb \u0dba\u0dcf\u0db8 \u0d89\u0dad\u0dcf\u0db8 \u0dc0\u0dd0\u0daf\u0d9c\u0dad\u0dca \u0dc0\u0dd9\u0db1\u0dc0\u0dcf.",
